<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Zephyr merge list</title>

<style>
/* Theme: every color lives in a variable so light and dark stay in sync. */
:root {
	--bg: #f6f7f9;
	--panel: #ffffff;
	--fg: #1d2531;
	--muted: #5d6b83;
	--border: #dce2eb;
	--accent: #6e37c8;
	--ok: #1a7f37;
	--ok-bg: #def0e3;
	--warn: #7d5c00;
	--warn-bg: #fdeeba;
	--bad: #b42323;
	--bad-bg: #fbe2e2;
	--neutral-bg: #e8ecf2;
	--stripe: #eef1f6;          /* even-row zebra band */
	--row-ready: #e4f6ea;       /* ready rows, overrides the zebra band */
	--row-hover: #e2e8f2;
	--header-bg: #333f67;
	--header-fg: #ffffff;
}
@media (prefers-color-scheme: dark) {
	:root {
		/* Lifted off pure black: the page, the panel and the zebra band sit
		 * on distinct, clearly separated steps so nothing reads as
		 * "dark on dark". */
		--bg: #10151d;
		--panel: #1e2735;
		--fg: #e8ecf4;
		--muted: #a3b0c6;
		--border: #38445a;
		--accent: #b48cf5;
		--ok: #56d47b;
		--ok-bg: #1c3a28;
		--warn: #edc84f;
		--warn-bg: #3d3410;
		--bad: #f77f7f;
		--bad-bg: #45201f;
		--neutral-bg: #2b3547;
		--stripe: #262f40;          /* even-row zebra band, a step above panel */
		--row-ready: #204a30;       /* clearly green, not near-black */
		--row-hover: #313d52;
		--header-bg: #2c3759;
		--header-fg: #e9eef9;
	}
}

/* Icon shapes, vendored from Material Icons (Apache-2.0) so status
 * symbols render identically everywhere instead of depending on
 * whichever glyphs the system font provides. */
:root {
	--icon-check: url('data:image/svg+xml,%3Csvg%20xmlns="http://www.w3.org/2000/svg"%20viewBox="0%200%2024%2024"%3E%3Cpath%20d="M9%2016.17L4.83%2012l-1.42%201.41L9%2019%2021%207l-1.41-1.41z"/%3E%3C/svg%3E');
	--icon-close: url('data:image/svg+xml,%3Csvg%20xmlns="http://www.w3.org/2000/svg"%20viewBox="0%200%2024%2024"%3E%3Cpath%20d="M19%206.41L17.59%205%2012%2010.59%206.41%205%205%206.41%2010.59%2012%205%2017.59%206.41%2019%2012%2013.41%2017.59%2019%2019%2017.59%2013.41%2012z"/%3E%3C/svg%3E');
	--icon-block: url('data:image/svg+xml,%3Csvg%20xmlns="http://www.w3.org/2000/svg"%20viewBox="0%200%2024%2024"%3E%3Cpath%20d="M12%202C6.48%202%202%206.48%202%2012s4.48%2010%2010%2010%2010-4.48%2010-10S17.52%202%2012%202zM4%2012c0-4.42%203.58-8%208-8%201.85%200%203.55.63%204.9%201.69L5.69%2016.9C4.63%2015.55%204%2013.85%204%2012zm8%208c-1.85%200-3.55-.63-4.9-1.69L18.31%207.1C19.37%208.45%2020%2010.15%2020%2012c0%204.42-3.58%208-8%208z"/%3E%3C/svg%3E');
	--icon-refresh: url('data:image/svg+xml,%3Csvg%20xmlns="http://www.w3.org/2000/svg"%20viewBox="0%200%2024%2024"%3E%3Cpath%20d="M17.65%206.35C16.2%204.9%2014.21%204%2012%204c-4.42%200-7.99%203.58-7.99%208s3.57%208%207.99%208c3.73%200%206.84-2.55%207.73-6h-2.08c-.82%202.33-3.04%204-5.65%204-3.31%200-6-2.69-6-6s2.69-6%206-6c1.66%200%203.14.69%204.22%201.78L13%2011h7V4l-2.35%202.35z"/%3E%3C/svg%3E');
}

/* Icons are drawn as masks over the text color. */
.ci-pass::before, .ci-fail::before, .ci-cancelled::before, .ci-running::before,
.gate-pass::before, .gate-fail::before {
	content: "";
	display: inline-block;
	width: 1em;
	height: 1em;
	vertical-align: -0.15em;
	background: currentColor;
	-webkit-mask: center / contain no-repeat;
	mask: center / contain no-repeat;
}
.ci-pass::before, .gate-pass::before {
	-webkit-mask-image: var(--icon-check);
	mask-image: var(--icon-check);
}
.ci-fail::before, .gate-fail::before {
	-webkit-mask-image: var(--icon-close);
	mask-image: var(--icon-close);
}
.ci-cancelled::before {
	-webkit-mask-image: var(--icon-block);
	mask-image: var(--icon-block);
}
.ci-running::before {
	-webkit-mask-image: var(--icon-refresh);
	mask-image: var(--icon-refresh);
}

* { box-sizing: border-box; }

body {
	margin: 0 auto;
	padding: 12px 24px 32px;
	background: var(--bg);
	color: var(--fg);
	font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	font-size: 14px;
	line-height: 1.4;
}

/* Keep the side padding from eating the narrow screens. */
@media (max-width: 640px) {
	body { padding: 8px 12px 24px; }
}

a { color: inherit; text-decoration: none; }
a:hover { text-decoration: underline; }

/* ---- Page header ------------------------------------------------------ */

.page-header { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
.page-header h1 { margin: 4px 0 0; font-size: 21px; }
.page-header .subtitle { color: var(--muted); margin: 0; }

/* The help is a quiet inline link, not a standalone button, so it costs
 * no vertical space of its own. */
.help-link {
	padding: 0;
	background: none;
	border: none;
	color: var(--accent);
	font: inherit;
	font-weight: 600;
	cursor: pointer;
	white-space: nowrap;
}
.help-link:hover { text-decoration: underline; }

/* ---- Summary bar ------------------------------------------------------- */

/* One compact line instead of a panel of cards: the same four facts
 * (ready count, CI on main, release phase, last update) laid out inline. */
.metabar {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 8px 14px;
	margin: 10px 0;
	padding: 8px 14px;
	background: var(--panel);
	border: 1px solid var(--border);
	border-radius: 8px;
	font-size: 13px;
}
.metabar .meta-label {
	color: var(--muted);
	font-weight: 600;
	margin-right: 4px;
}
.metabar .meta-ready { font-size: 15px; font-weight: 600; }
.metabar .meta-ready b { color: var(--ok); }
.metabar .meta-sep { color: var(--border); }

.ci-badges { display: inline-flex; flex-wrap: wrap; gap: 6px; vertical-align: middle; }

.ci-badge {
	display: inline-block;
	padding: 1px 8px;
	border-radius: 999px;
	font-size: 12px;
	background: var(--neutral-bg);
	white-space: nowrap;
}
.ci-badge::before { margin-right: 4px; }
.ci-pass { background: var(--ok-bg); color: var(--ok); }
.ci-fail { background: var(--bad-bg); color: var(--bad); }
.ci-cancelled { background: var(--warn-bg); color: var(--warn); }
.ci-running { background: var(--neutral-bg); color: var(--accent); font-weight: 600; }
.ci-running::before { animation: ci-spin 2s linear infinite; }
@keyframes ci-spin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) {
	.ci-running::before { animation: none; }
}

/* ---- MOTD banner ------------------------------------------------------- */

.motd {
	border: 1px solid var(--bad);
	border-left-width: 6px;
	border-radius: 8px;
	background: var(--bad-bg);
	padding: 10px 14px;
	margin: 12px 0;
}

/* ---- Filter controls ---------------------------------------------------- */

.controls {
	display: flex;
	align-items: center;
	gap: 12px;
	flex-wrap: wrap;
	margin: 12px 0;
}

#pr-search {
	padding: 6px 12px;
	min-width: 280px;
	background: var(--panel);
	color: var(--fg);
	border: 1px solid var(--border);
	border-radius: 6px;
	font-size: 13px;
}
#pr-search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }

.chips { display: flex; gap: 6px; flex-wrap: wrap; }

.chip {
	padding: 4px 12px;
	background: var(--panel);
	color: var(--muted);
	border: 1px solid var(--border);
	border-radius: 999px;
	font-size: 13px;
	font-weight: 600;
	cursor: pointer;
}
.chip:hover { border-color: var(--accent); }
.chip.active {
	background: var(--accent);
	border-color: var(--accent);
	color: var(--bg);
}
.chip .count { font-weight: 400; opacity: 0.8; }

/* The target group is set apart from the status chips by a divider. */
#target-chips { border-left: 1px solid var(--border); padding-left: 12px; }
.chips-label { color: var(--muted); font-size: 13px; align-self: center; }

/* ---- Table ------------------------------------------------------------- */

.table-wrap {
	background: var(--panel);
	border: 1px solid var(--border);
	border-radius: 8px;
	/* No overflow container here: an overflow-x:auto wrapper turns into a
	 * scroll container on both axes, which pins the sticky header to the
	 * wrapper (that never scrolls vertically) instead of the viewport, so
	 * it scrolls off with the page. Letting the page own the scrolling
	 * keeps the header stuck to the top of the window; a table too wide
	 * for a narrow screen scrolls with the page instead. */
}

.prs { border-collapse: collapse; width: 100%; }

.prs th, .prs td {
	padding: 3px 10px;
	border-bottom: 1px solid var(--border);
	text-align: left;
	vertical-align: top;
}

.prs thead th {
	position: sticky;
	top: 0;
	z-index: 1;
	background: var(--header-bg);
	color: var(--header-fg);
	font-size: 12px;
	white-space: nowrap;
	cursor: help;
	padding-top: 6px;
	padding-bottom: 6px;
}

/* Sortable columns: pointer cursor plus an arrow when a sort is active. */
.prs thead th.sortable { cursor: pointer; user-select: none; }
.prs thead th.sortable[aria-sort="ascending"]::after { content: " \25B4"; }
.prs thead th.sortable[aria-sort="descending"]::after { content: " \25BE"; }

.prs tfoot td { color: var(--muted); text-align: center; padding: 16px; }

.prs tbody tr:last-child td { border-bottom: none; }

/* Row backgrounds, in increasing order of precedence (later rules win at
 * equal specificity):
 *   1. zebra banding on even rows for readability across wide rows;
 *   2. ready rows are tinted green regardless of parity (this, plus the
 *      three green gate ticks, is how "ready" reads now the status column
 *      is gone);
 *   3. hover always wins.
 * Which branch a PR targets is left to the Target column and its filter,
 * so no extra per-row shading competes with the banding. */
.prs tbody tr.stripe { background: var(--stripe); }
.prs tbody tr[data-status="ready"] { background: var(--row-ready); }
.prs tbody tr:hover { background: var(--row-hover); }

.prs td.num, .prs td.gate { white-space: nowrap; }
.prs td.gate { text-align: center; }
.prs th.gate-col { text-align: center; }

.gate-pass { color: var(--ok); font-weight: 600; }
.gate-fail { color: var(--bad); font-weight: 600; }
.gate-wait { color: var(--warn); font-weight: 600; white-space: nowrap; }
.gate-unknown { color: var(--muted); }

.muted { color: var(--muted); }

/* ---- Label tags (shown next to PR titles) ------------------------------ */

.tag {
	display: inline-block;
	padding: 0 6px;
	border-radius: 4px;
	font-size: 11px;
	font-weight: 600;
	white-space: nowrap;
	cursor: default;
}
.tag-hotfix { background: #b60205; color: white; }
.tag-trivial { background: #f9d0b1; color: #402000; }
.tag-override { background: #6f42c1; color: white; }
.tag-oldci { background: #fef2c0; color: #574b00; }
.tag-dismissed { background: #ff69b4; color: #3d0d24; }
.tag-dnm { background: #b60205; color: white; }

/* ---- Footer / misc ----------------------------------------------------- */

.toolbar {
	display: flex;
	align-items: center;
	gap: 16px;
	flex-wrap: wrap;
	margin: 12px 0;
}

.open-ready-button {
	padding: 6px 14px;
	background: var(--ok);
	color: var(--bg);
	border: none;
	border-radius: 6px;
	font-size: 13px;
	font-weight: 600;
	cursor: pointer;
}
.open-ready-button:hover { filter: brightness(1.15); }

/* ---- Help dialog -------------------------------------------------------- */

/* Slightly larger text than the page: the dialog is meant to be read. */
dialog.help {
	margin: auto;
	max-width: 720px;
	width: calc(100vw - 48px);
	padding: 0;
	background: var(--panel);
	color: var(--fg);
	border: 1px solid var(--border);
	border-radius: 12px;
	box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
	font-size: 15px;
	line-height: 1.55;
}
dialog.help::backdrop { background: rgba(0, 0, 0, 0.5); }

/* The padding lives on the body so clicks on the dialog element itself
 * can only come from the backdrop (see setupHelpDialog). */
.help-body { padding: 20px 28px 24px; }

.help-header { display: flex; align-items: center; justify-content: space-between; }
.help-header h3 { margin: 0; font-size: 19px; }

.help-close {
	padding: 2px 8px;
	background: none;
	color: var(--muted);
	border: none;
	font-size: 16px;
	cursor: pointer;
}
.help-close:hover { color: var(--fg); }

.help h4 { margin: 16px 0 4px; }
.help td, .help th { padding: 2px 10px 2px 0; text-align: left; vertical-align: top; }
.help a { color: var(--accent); }

footer { margin-top: 20px; color: var(--muted); font-size: 12px; }
footer img { vertical-align: middle; }
</style>

<script>
"use strict";

/* Message of the day: maintained on the Zephyr wiki, shown when not "empty". */
function loadMotd() {
	const url = "https://raw.githubusercontent.com/wiki/zephyrproject-rtos/zephyr/Merge-List-MOTD.md";
	fetch(url)
		.then((response) => {
			if (!response.ok) {
				throw new Error("HTTP error: " + response.status);
			}
			return response.text();
		})
		.then((text) => {
			if (text.trim() == "empty") {
				return;
			}
			const banner = document.getElementById("motd");
			banner.textContent = text;
			banner.hidden = false;
		})
		.catch((error) => console.log("motd: " + error));
}

/* Show "12 minutes ago" instead of a raw ISO timestamp. */
const rtf = new Intl.RelativeTimeFormat(undefined, { numeric: "auto" });

function renderUpdateTime() {
	const el = document.getElementById("update-timestamp");
	const then = Date.parse(el.getAttribute("datetime"));
	if (isNaN(then)) {
		return;
	}
	const seconds = Math.round((then - Date.now()) / 1000);

	let text;
	if (Math.abs(seconds) < 60) {
		text = rtf.format(seconds, "second");
	} else if (Math.abs(seconds) < 3600) {
		text = rtf.format(Math.round(seconds / 60), "minute");
	} else if (Math.abs(seconds) < 86400) {
		text = rtf.format(Math.round(seconds / 3600), "hour");
	} else {
		text = rtf.format(Math.round(seconds / 86400), "day");
	}
	el.textContent = text;
	el.title = new Date(then).toString();
}

/* Auto-refresh: poll with a HEAD request once a minute and reload only
 * when the page validators say a new version was actually published,
 * so nothing on screen ever moves for nothing. */
function setupAutoRefresh() {
	let current = null;

	function check() {
		fetch(location.href, { method: "HEAD", cache: "no-store" })
			.then((response) => {
				const version = response.headers.get("ETag") ||
					response.headers.get("Last-Modified");
				if (current && version && version != current) {
					location.reload();
				}
				current = version || current;
			})
			.catch((error) => console.log("auto-refresh: " + error));
	}

	check();
	setInterval(check, 60000);
}

/* Open every ready PR currently shown in the table that targets main,
 * each in its own tab. Most browsers allow a single popup per click
 * and silently block the rest (window.open returns null), so count
 * the casualties and tell the user how to lift the limit instead of
 * failing mysteriously. */
function openReadyPRs() {
	const rows = [...document.querySelectorAll(
		'#pr-table tbody tr[data-status="ready"][data-base="main"]')]
		.filter((row) => !row.hidden);

	if (rows.length == 0) {
		alert("No ready PRs targeting main in the current view.");
		return;
	}
	const blocked = rows.filter((row) => {
		const link = row.querySelector("a");
		return link && window.open(link.href, "_blank") == null;
	}).length;

	if (blocked > 0) {
		alert(`The browser blocked ${blocked} of ${rows.length} tabs. ` +
			"Allow pop-ups for this site (look for the blocked pop-up " +
			"icon in the address bar) to open all ready PRs at once.");
	}
}

/* Zebra-stripe the currently visible rows. Driven from JS rather than
 * CSS :nth-child so the banding stays correct after rows are hidden by a
 * filter or reordered by a sort, instead of leaving parity gaps. */
function restripe() {
	let visible = 0;
	document.querySelectorAll("#pr-table tbody tr").forEach((row) => {
		if (row.hidden) {
			return;
		}
		row.classList.toggle("stripe", visible % 2 == 1);
		visible++;
	});
}

/* Build one filter chip per target branch found in the table, "main"
 * first. The chip group only appears when there is a choice to make. */
function buildTargetChips(rows) {
	const group = document.getElementById("target-chips");

	const counts = new Map();
	rows.forEach((row) => {
		counts.set(row.dataset.base, (counts.get(row.dataset.base) || 0) + 1);
	});

	const bases = [...counts.keys()].sort(
		(a, b) => (a != "main") - (b != "main") || a.localeCompare(b));
	["", ...bases].forEach((base) => {
		const chip = document.createElement("button");
		chip.className = "chip";
		chip.dataset.target = base;
		chip.textContent = base || "All";
		chip.insertAdjacentHTML("beforeend",
			` <span class="count">${base ? counts.get(base) : rows.length}</span>`);
		group.appendChild(chip);
	});
	group.hidden = bases.length < 2;
}

/* Text search, status chips and target branch chips; a row must match
 * all three to stay visible. Chip selections are remembered across
 * visits (localStorage); the text filter only lasts for the tab. */
function setupFilters() {
	const search = document.getElementById("pr-search");
	const rows = [...document.querySelectorAll("#pr-table tbody tr")];
	const noMatch = document.getElementById("no-match");

	buildTargetChips(rows);
	const statusChips = [...document.querySelectorAll("#status-chips .chip")];
	const targetChips = [...document.querySelectorAll("#target-chips .chip")];

	const rowText = new Map(
		rows.map((row) => [row, row.textContent.toLowerCase()]));

	const counts = {};
	rows.forEach((row) => {
		counts[row.dataset.status] = (counts[row.dataset.status] || 0) + 1;
	});
	statusChips.forEach((chip) => {
		const count = chip.dataset.status
			? counts[chip.dataset.status] || 0
			: rows.length;
		chip.hidden = chip.hidden && count == 0;
		chip.insertAdjacentHTML("beforeend", ` <span class="count">${count}</span>`);
	});

	function apply() {
		const text = search.value.trim().toLowerCase();
		const status = document.querySelector("#status-chips .active").dataset.status;
		const target = document.querySelector("#target-chips .active").dataset.target;

		let shown = 0;
		const candidates = [];
		rows.forEach((row) => {
			const matchText = !text || rowText.get(row).includes(text);
			const matchStatus = !status || row.dataset.status == status;
			const matchTarget = !target || row.dataset.base == target;

			if (matchText) {
				candidates.push({row, matchStatus, matchTarget});
			}
			const match = matchText && matchStatus && matchTarget;
			row.hidden = !match;
			shown += match;
		});
		noMatch.hidden = shown > 0;

		/* Live chip counts: how many rows clicking the chip would show,
		 * i.e. the other filters apply but the chip's own group does not. */
		statusChips.forEach((chip) => {
			const value = chip.dataset.status;
			chip.querySelector(".count").textContent = candidates.filter(
				(c) => c.matchTarget &&
					(!value || c.row.dataset.status == value)).length;
		});
		targetChips.forEach((chip) => {
			const value = chip.dataset.target;
			chip.querySelector(".count").textContent = candidates.filter(
				(c) => c.matchStatus &&
					(!value || c.row.dataset.base == value)).length;
		});

		restripe();

		sessionStorage.setItem("filterText", text);
		localStorage.setItem("filterStatus", status);
		localStorage.setItem("filterTarget", target);
	}

	search.addEventListener("input", apply);

	/* One chip per group is active; clicking moves the highlight. The
	 * previous selection is restored from localStorage, falling back
	 * to the group's first ("All") chip when it no longer exists. */
	function setupChips(chips, key, saved) {
		chips.forEach((chip) => {
			chip.addEventListener("click", () => {
				chips.forEach((c) => c.classList.remove("active"));
				chip.classList.add("active");
				apply();
			});
			chip.classList.toggle("active",
				chip.dataset[key] == saved && !chip.hidden);
		});
		if (!chips.some((chip) => chip.classList.contains("active"))) {
			chips[0].classList.add("active");
		}
	}

	search.value = sessionStorage.getItem("filterText") || "";
	setupChips(statusChips, "status",
		localStorage.getItem("filterStatus") || "");
	setupChips(targetChips, "target",
		localStorage.getItem("filterTarget") || "");
	apply();
}

/* Click a column header to sort; click again to reverse. */
function setupSorting() {
	const table = document.getElementById("pr-table");

	function sortValue(row, column, kind) {
		const text = row.cells[column].textContent.trim();
		return kind == "number" ? parseInt(text, 10) : text.toLowerCase();
	}

	table.querySelectorAll("th.sortable").forEach((th) => {
		th.addEventListener("click", () => {
			const ascending = th.getAttribute("aria-sort") != "ascending";
			table.querySelectorAll("th.sortable").forEach(
				(other) => other.removeAttribute("aria-sort"));
			th.setAttribute("aria-sort", ascending ? "ascending" : "descending");

			const tbody = table.tBodies[0];
			const column = th.cellIndex;
			const kind = th.dataset.sort;
			Array.from(tbody.rows)
				.map((row) => [sortValue(row, column, kind), row])
				.sort(([a], [b]) => {
					const cmp = a < b ? -1 : a > b ? 1 : 0;
					return ascending ? cmp : -cmp;
				})
				.forEach(([, row]) => tbody.appendChild(row));
			restripe();
		});
	});
}

/* Close the help dialog when the backdrop is clicked; Esc already works
 * natively. Clicks inside the content land on .help-body, not here. */
function setupHelpDialog() {
	const dialog = document.getElementById("help-dialog");
	dialog.addEventListener("click", (event) => {
		if (event.target == dialog) {
			dialog.close();
		}
	});
}

addEventListener("DOMContentLoaded", () => {
	loadMotd();
	renderUpdateTime();
	setInterval(renderUpdateTime, 30000);
	setupAutoRefresh();
	setupFilters();
	setupSorting();
	setupHelpDialog();
});
</script>

</head>

<body>

<div class="page-header">
	<h1>Zephyr merge list</h1>
	<p class="subtitle">Open pull requests that are approved, pass CI, and are
	in line to be merged into
	<a href="https://github.com/zephyrproject-rtos/zephyr">zephyrproject-rtos/zephyr</a>.
	<button class="help-link"
		onclick="document.getElementById('help-dialog').showModal()">How this list
		works</button></p>
</div>

<dialog class="help" id="help-dialog" aria-labelledby="help-title">
	<div class="help-body">
	<div class="help-header">
		<h3 id="help-title">How this list works</h3>
		<button class="help-close" aria-label="Close"
			onclick="document.getElementById('help-dialog').close()">&#10005;</button>
	</div>

	<h4>Which PRs show up here?</h4>
	<p>Every open, non-draft pull request that is approved by reviewers and
	passing CI. Code review is done: this page tracks the final wait for a
	release engineer to apply the project's
	<a href="https://docs.zephyrproject.org/latest/project/release_process.html#pull-request-merge-criteria">merge criteria</a>.</p>

	<h4>The three merge gates</h4>
	<p>A PR is merged once all three pass:</p>
	<ol>
		<li><b>Conflict-free</b>: the PR applies cleanly on its target
		branch, no rebase needed.</li>
		<li><b>Assignee approval</b>: the assigned maintainer approved the
		PR. Auto-passes for hotfixes, unassigned PRs, and authors who are
		their own assignee.</li>
		<li><b>Review time</b>: {{REVIEW_WINDOW_BIZ_HOURS}} business hours
		since the PR became ready for review, so everyone gets a chance to
		comment. {{REVIEW_WINDOW_TRIVIAL_HOURS}} hours for <i>trivial</i>
		PRs, none for <i>hotfixes</i>.</li>
	</ol>
	<p>The three gate columns show each gate at a glance: a green tick means
	passed, a red cross means the author or assignee still needs to act, and
	the review-time column counts down the hours left. A row whose three
	gates are all green is tinted green and ready to merge &mdash; it will be
	picked up in the next merge round. Use the <b>Ready</b> / <b>Waiting</b> /
	<b>Blocked</b> chips above the table to filter.</p>

	<h4><a href="https://docs.zephyrproject.org/latest/project/dev_env_and_tools.html#labeling-issues-and-pull-requests-in-github">Labels</a></h4>
	<table>
		<tr><td><span class="tag tag-hotfix">hotfix</span></td>
			<td>Fixes a broken main branch; merged immediately.</td></tr>
		<tr><td><span class="tag tag-trivial">trivial</span></td>
			<td>Small, low-risk change; the review window is {{REVIEW_WINDOW_TRIVIAL_HOURS}} hours instead of {{REVIEW_WINDOW_BIZ_HOURS}} business hours.</td></tr>
		<tr><td><span class="tag tag-override">override required</span></td>
			<td>A release engineer must override a failing or stuck required check to merge.</td></tr>
		<tr><td><span class="tag tag-oldci">ci 42d</span></td>
			<td>The last full CI run is that many days old; CI should be re-run before merging.</td></tr>
		<tr><td><span class="tag tag-dismissed">review dismissed</span></td>
			<td>A &ldquo;changes requested&rdquo; review was dismissed by someone else; merits a second look.</td></tr>
		<tr><td><span class="tag tag-dnm">dnm</span></td>
			<td>Do not merge.</td></tr>
	</table>

	<h4>Release phase</h4>
	<p>During <b>integration</b>, features and fixes merge normally. During
	<a href="https://docs.zephyrproject.org/latest/project/release_process.html#feature-freeze-stabilization-phase">feature
	freeze</a>, only bug fixes and release-blocking work are merged, and PRs
	milestoned for the next release wait.</p>
	</div>
</dialog>

<div class="motd" id="motd" role="alert" hidden></div>

<div class="metabar">
	<span class="meta-ready"><b>{{READY_COUNT}}</b> of {{TOTAL_COUNT}} ready to merge</span>
	<span class="meta-sep">|</span>
	<span><span class="meta-label">CI on main:</span><span class="ci-badges">{{CI_STATUS}}</span></span>
	<span class="meta-sep">|</span>
	<span title="{{RELEASE_PHASE_HINT}}"><span class="meta-label">Phase:</span>{{RELEASE_PHASE}} <span class="muted">&middot; {{RELEASE_PHASE_DETAIL}}</span></span>
	<span class="meta-sep">|</span>
	<span><span class="meta-label">Updated</span><time id="update-timestamp" datetime="{{UPDATE_TIMESTAMP}}">{{UPDATE_TIMESTAMP}}</time></span>
</div>

<div class="controls">
	<input type="search" id="pr-search"
		placeholder="Filter by number, title, author, branch&hellip;"
		aria-label="Filter pull requests">
	<div class="chips" id="status-chips" role="group" aria-label="Filter by status">
		<button class="chip active" data-status="">All</button>
		<button class="chip" data-status="ready">Ready</button>
		<button class="chip" data-status="waiting">Waiting</button>
		<button class="chip" data-status="blocked">Blocked</button>
		<button class="chip" data-status="unknown" hidden>Checking</button>
	</div>
	<!-- Filled by setupFilters(): one chip per target branch in the table. -->
	<div class="chips" id="target-chips" role="group"
		aria-label="Filter by target branch" hidden>
		<span class="chips-label">Target branch:</span>
	</div>
</div>

<div class="table-wrap">
<table class="prs" id="pr-table">
	<thead>
	<tr>
		<th class="sortable" data-sort="number" title="Pull request number (click to sort)">PR</th>
		<th class="sortable" data-sort="text" title="Pull request title and labels (click to sort)">Title</th>
		<th class="gate-col" title="Gate 1: the PR applies cleanly on its target branch (no merge conflicts)">Conflict&#8209;free</th>
		<th class="gate-col" title="Gate 2: an assignee approved the PR (auto-passes for hotfixes, unassigned PRs, or when the author is the assignee)">Assignee approval</th>
		<th class="gate-col" title="Gate 3: the minimum review window has elapsed &mdash; {{REVIEW_WINDOW_BIZ_HOURS}} business hours, {{REVIEW_WINDOW_TRIVIAL_HOURS}} hours for trivial PRs, none for hotfixes">Review time</th>
		<th class="sortable" data-sort="text" title="Who opened the PR (click to sort)">Author</th>
		<th class="sortable" data-sort="text" title="Maintainers assigned to shepherd the PR (click to sort)">Assignees</th>
		<th class="sortable" data-sort="text" title="Reviewers whose approval currently stands (click to sort)">Approvers</th>
		<th class="sortable" data-sort="text" title="Branch the PR will be merged into, plus its milestone if set (click to sort)">Target</th>
	</tr>
	</thead>
	<tbody>
<!-- PR_ROWS -->
	</tbody>
	<tfoot>
	<tr id="no-match" hidden><td colspan="9">No pull requests match the current filter.</td></tr>
	</tfoot>
</table>
</div>

<div class="toolbar">
	<button onclick="openReadyPRs()" class="open-ready-button">Open all ready PRs &nearr;</button>
</div>

<footer>
	<a href="https://github.com/{{REPOSITORY_PATH}}/actions/workflows/update.yaml">
		<img src="https://github.com/{{REPOSITORY_PATH}}/actions/workflows/update.yaml/badge.svg" alt="update workflow status">
	</a>
	&mdash; generated by <a href="https://github.com/{{REPOSITORY_PATH}}">{{REPOSITORY_PATH}}</a>
</footer>

</body>
</html>
