<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Zephyr merge list</title>

<link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.8/css/responsive.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/fixedheader/4.0.6/css/fixedHeader.dataTables.min.css">

<style>
:root {
	--bg: #f6f7f9;
	--panel: #ffffff;
	--fg: #1d2531;
	--muted: #5d6b83;
	--border: #dce2eb;
	--row-divider: #c3ccd9;
	--accent: #6e37c8;
	--ok: #1a7f37;
	--ok-bg: #def0e3;
	--warn: #7d5c00;
	--warn-bg: #fdeeba;
	--bad: #b42323;
	--bad-bg: #fbe2e2;
	--neutral-bg: #e8ecf2;
	--stripe: #eef1f6;
	--row-ready: #e4f6ea;
	--row-ready-hover: #d3efdc;
	--row-hover: #e2e8f2;
	--header-bg: #333f67;
	--header-fg: #ffffff;
	--pad: 24px;
}
@media (prefers-color-scheme: dark) {
	:root {
		--bg: #10151d;
		--panel: #1e2735;
		--fg: #e8ecf4;
		--muted: #a3b0c6;
		--border: #38445a;
		--row-divider: #50617b;
		--accent: #b48cf5;
		--ok: #56d47b;
		--ok-bg: #1c3a28;
		--warn: #edc84f;
		--warn-bg: #3d3410;
		--bad: #f77f7f;
		--bad-bg: #45201f;
		--neutral-bg: #2b3547;
		--stripe: #262f40;
		--row-ready: #204a30;
		--row-ready-hover: #2b5c3e;
		--row-hover: #313d52;
		--header-bg: #2c3759;
		--header-fg: #e9eef9;
	}
}

* { box-sizing: border-box; }
html { overscroll-behavior-y: none; }
body {
	margin: 0;
	padding: 0 var(--pad) 16px;
	background: var(--bg);
	color: var(--fg);
	font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	font-size: 14px;
	line-height: 1.4;
}
a { color: inherit; text-decoration: none; }
a:hover { text-decoration: underline; }

@media (max-width: 640px) {
	:root { --pad: 12px; }
	body { padding-bottom: 12px; }
	.page-header { padding-top: 8px; }
	/* Shrink a notch so the author column fits alongside PR, title, gate. */
	.prs { font-size: 0.9em; }
	/* The icons carry the meaning; drop the heading text to save width. */
	.prs thead th.gate-col,
	table.dataTable.prs > thead > tr > th.gate-col { font-size: 0; }
	/* Author is the only handle column on phones; keep it off the title. */
	.prs td.author a {
		display: inline-block;
		max-width: 7em;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		vertical-align: bottom;
	}
}

/* ---- Page header ------------------------------------------------------ */

.page-header {
	display: flex;
	align-items: baseline;
	gap: 10px;
	flex-wrap: wrap;
	padding-top: 12px;
}
.page-header h1 { margin: 4px 0 0; font-size: 21px; }
.page-header .subtitle { color: var(--muted); margin: 0; }

.help-link {
	padding: 0;
	background: none;
	border: none;
	color: var(--accent);
	font: inherit;
	font-weight: 600;
	cursor: pointer;
	white-space: nowrap;
}
.help-link:hover { text-decoration: underline; }

/* ---- Summary bar ------------------------------------------------------- */

.metabar {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 8px 14px;
	margin: 10px 0;
	padding: 8px 14px;
	background: var(--panel);
	border: 1px solid var(--border);
	border-radius: 8px;
	font-size: 13px;
}
.metabar .meta-label { color: var(--muted); font-weight: 600; margin-right: 4px; }
.metabar .meta-sep { color: var(--border); }
#update-timestamp.stale { color: var(--warn); font-weight: 600; }
#update-timestamp.very-stale { color: var(--bad); font-weight: 600; }

.ci-badges { display: inline-flex; flex-wrap: wrap; gap: 6px; vertical-align: middle; }
.ci-badge {
	display: inline-block;
	padding: 1px 8px;
	border-radius: 999px;
	font-size: 12px;
	background: var(--neutral-bg);
	white-space: nowrap;
}
.ci-badge .lucide { width: 1em; height: 1em; margin-right: 4px; vertical-align: -0.15em; }
.ci-pass { background: var(--ok-bg); color: var(--ok); }
.ci-fail { background: var(--bad-bg); color: var(--bad); }
.ci-cancelled { background: var(--warn-bg); color: var(--warn); }
.ci-running { background: var(--neutral-bg); color: var(--accent); font-weight: 600; }
.ci-running .lucide { animation: ci-spin 2s linear infinite; }
@keyframes ci-spin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) {
	.ci-running .lucide { animation: none; }
}

/* ---- MOTD banner ------------------------------------------------------- */

.motd {
	border: 1px solid var(--bad);
	border-left-width: 6px;
	border-radius: 8px;
	background: var(--bad-bg);
	padding: 10px 14px;
	margin: 12px 0;
}

/* ---- Filter controls ---------------------------------------------------- */

/* Sticky filter bar; FixedHeader positions the table headings just below. */
.controls {
	display: flex;
	align-items: center;
	gap: 12px;
	flex-wrap: wrap;
	margin: 0 calc(-1 * var(--pad));
	padding: 10px var(--pad);
	position: sticky;
	top: 0;
	z-index: 4;
	background: var(--bg);
}

#pr-search {
	padding: 6px 12px;
	min-width: 280px;
	background: var(--panel);
	color: var(--fg);
	border: 1px solid var(--border);
	border-radius: 6px;
	font-size: 13px;
}
#pr-search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }

.chips { display: flex; gap: 6px; flex-wrap: wrap; }
.chips-label { color: var(--muted); font-size: 13px; align-self: center; }
#target-chips { border-left: 1px solid var(--border); padding-left: 12px; }

.chip {
	padding: 4px 12px;
	background: var(--panel);
	color: var(--muted);
	border: 1px solid var(--border);
	border-radius: 999px;
	font-size: 13px;
	font-weight: 600;
	cursor: pointer;
}
.chip:hover { border-color: var(--accent); }
.chip.active { background: var(--accent); border-color: var(--accent); color: var(--bg); }
.chip .count { font-weight: 400; opacity: 0.8; }

/* ---- Table ------------------------------------------------------------- */

.table-wrap {
	background: var(--panel);
	border: 1px solid var(--border);
	border-radius: 0 0 8px 8px;
}

.prs { border-collapse: collapse; width: 100%; }
table.dataTable.prs { margin: 0 !important; width: 100% !important; border-collapse: collapse; }

/* Base cells plus the matching DataTables overrides, so pre- and post-init look identical. */
.prs th, .prs td,
table.dataTable.prs > thead > tr > th,
table.dataTable.prs > tbody > tr > td {
	padding: 3px 10px;
	border-bottom: 1px solid var(--row-divider);
	text-align: left;
	vertical-align: top;
}
.prs thead th,
table.dataTable.prs > thead > tr > th {
	padding-top: 6px;
	padding-bottom: 6px;
	background: var(--header-bg);
	color: var(--header-fg);
	font-size: 12px;
	white-space: nowrap;
	cursor: help;
	border-bottom: none;
	box-shadow: inset 0 -1px 0 var(--border);
}
.prs tbody tr:last-child td { border-bottom: none; }

table.dataTable.prs > thead > tr > th.dt-orderable-asc,
table.dataTable.prs > thead > tr > th.dt-orderable-desc {
	padding-right: 18px;
	cursor: pointer;
	user-select: none;
}
table.dataTable.prs > tbody > tr > td.dt-type-numeric { text-align: left; }

/* Row expand/collapse triangle in the text colour (its faint-black default is
 * invisible on the dark theme, which only ships a Bootstrap-class override). */
table.dataTable.prs > tbody > tr:not(.dtr-expanded) > td.dtr-control::before { border-left-color: currentColor !important; }
table.dataTable.prs > tbody > tr.dtr-expanded > td.dtr-control::before { border-top-color: currentColor !important; }

.prs td.num, .prs td.gate { white-space: nowrap; }
.prs td.title { overflow-wrap: anywhere; }
/* Wrap the assignee/approver names into a bounded column instead of one long line. */
.prs td.people .handles {
	display: inline-block;
	max-width: 12em;
	overflow-wrap: anywhere;
}
/* Wide screens have the room, so let the lists spread rather than wrap. */
@media (min-width: 1300px) {
	.prs td.people .handles { max-width: 24em; }
}
/* Precedence: stripe < ready < hover (later rules win at equal specificity). */
.prs tbody tr.stripe { background: var(--stripe); }
.prs tbody tr[data-status="ready"] { background: var(--row-ready); }
.prs tbody tr:hover { background: var(--row-hover); }
.prs tbody tr[data-status="ready"]:hover { background: var(--row-ready-hover); }

.gate-icons {
	display: inline-grid;
	grid-template-columns: 18px 18px auto;
	align-items: center;
	justify-items: start;
	column-gap: 4px;
	vertical-align: middle;
}
.gate-icon { display: inline-flex; align-items: center; justify-content: center; gap: 3px; }
.gate-icon .lucide { width: 16px; height: 16px; flex: none; }

/* Hours-left as a small exponent riding the clock icon. */
.gate-num {
	margin-left: -2px;
	align-self: flex-start;
	line-height: 1;
	font-size: 0.8em;
	font-weight: 300;
}

.gate-pass, .gate-fail, .gate-wait { font-weight: 600; }
.gate-pass { color: var(--ok); }
.gate-fail { color: var(--bad); }
.gate-wait { color: var(--warn); white-space: nowrap; }
.gate-unknown { color: var(--muted); }

.muted { color: var(--muted); }

.table-wrap .dt-container .dt-layout-row { margin: 0; }
.table-wrap .dt-container .dt-layout-cell { padding: 0; }
table.dataTable.prs > tbody > tr.child ul.dtr-details > li { border-bottom-color: var(--border); }
table.dataTable.prs > tbody > tr > td.dt-empty { padding: 16px; color: var(--muted); text-align: center; }

/* ---- Label tags (shown next to PR titles) ------------------------------ */

.tag {
	display: inline-block;
	padding: 0 6px;
	border-radius: 4px;
	font-size: 11px;
	font-weight: 600;
	white-space: nowrap;
	cursor: default;
}
.tag-hotfix { background: #b60205; color: white; }
.tag-trivial { background: #f9d0b1; color: #402000; }
.tag-override { background: #6f42c1; color: white; }
.tag-oldci { background: #fef2c0; color: #574b00; }
.tag-dismissed { background: #ff69b4; color: #3d0d24; }
.tag-dnm { background: #b60205; color: white; }

/* ---- Footer / misc ----------------------------------------------------- */

.toolbar { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin: 12px 0; }

.open-ready-button {
	padding: 6px 14px;
	background: var(--ok);
	color: var(--bg);
	border: none;
	border-radius: 6px;
	font-size: 13px;
	font-weight: 600;
	cursor: pointer;
}
.open-ready-button:hover { filter: brightness(1.15); }

.phase { margin: 16px 0 0; font-size: 13px; }
footer { margin-top: 20px; color: var(--muted); font-size: 12px; }
footer img { vertical-align: middle; }

/* ---- Help dialog -------------------------------------------------------- */

dialog.help {
	margin: auto;
	max-width: 720px;
	width: calc(100vw - 48px);
	padding: 0;
	background: var(--panel);
	color: var(--fg);
	border: 1px solid var(--border);
	border-radius: 12px;
	box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
	font-size: 15px;
	line-height: 1.55;
}
dialog.help::backdrop { background: rgba(0, 0, 0, 0.5); }

/* Padding on the body so backdrop clicks land on the dialog itself (see setupHelpDialog). */
.help-body { padding: 20px 28px 24px; }

.help-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding-bottom: 10px;
	border-bottom: 1px solid var(--border);
}
.help-header h3 {
	margin: 0;
	padding-left: 10px;
	border-left: 3px solid var(--accent);
	font-size: 18px;
	line-height: 1.25;
	letter-spacing: 0.01em;
}
.help-close {
	padding: 2px 8px;
	background: none;
	color: var(--muted);
	border: none;
	font-size: 16px;
	cursor: pointer;
}
.help-close:hover { color: var(--fg); }

.help h4 {
	display: flex;
	align-items: center;
	gap: 8px;
	margin: 16px 0 5px;
	font-size: 1em;
	line-height: 1.35;
	letter-spacing: 0.015em;
}
.help h4::before {
	content: "";
	width: 6px;
	height: 6px;
	flex: 0 0 6px;
	border-radius: 50%;
	background: var(--accent);
}
.help h4 a { color: inherit; }
.help a { color: var(--accent); }
.help td, .help th { padding: 2px 10px 2px 0; text-align: left; vertical-align: top; }

.help-gates { display: grid; gap: 5px; margin: 6px 0; padding: 0; list-style: none; }
.help-gates li { display: grid; grid-template-columns: 20px 1fr; gap: 7px; align-items: start; }
.help-gates .gate-icon { margin-top: 0.2em; }
.help-gate-note { display: flex; align-items: center; gap: 7px; }
.help-gate-note .gate-icon { flex: none; }
</style>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/2.3.8/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/responsive/3.0.8/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/fixedheader/4.0.6/js/dataTables.fixedHeader.min.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>

<script>
"use strict";

let prTable;

/* Message of the day: maintained on the Zephyr wiki, shown when not "empty". */
function loadMotd() {
	const url = "https://raw.githubusercontent.com/wiki/zephyrproject-rtos/zephyr/Merge-List-MOTD.md";
	fetch(url)
		.then((response) => {
			if (!response.ok) {
				throw new Error("HTTP error: " + response.status);
			}
			return response.text();
		})
		.then((text) => {
			if (text.trim() == "empty") {
				return;
			}
			const banner = document.getElementById("motd");
			banner.textContent = text;
			banner.hidden = false;
		})
		.catch((error) => console.log("motd: " + error));
}

/* Show "12 minutes ago" instead of a raw ISO timestamp. */
const rtf = new Intl.RelativeTimeFormat(undefined, { numeric: "auto" });

function renderUpdateTime() {
	const el = document.getElementById("update-timestamp");
	const then = Date.parse(el.getAttribute("datetime"));
	if (isNaN(then)) {
		return;
	}
	const seconds = Math.round((then - Date.now()) / 1000);

	const minutes = Math.abs(seconds) / 60;
	el.classList.toggle("stale", minutes >= 40 && minutes < 60);
	el.classList.toggle("very-stale", minutes >= 60);

	let text;
	if (Math.abs(seconds) < 60) {
		text = rtf.format(seconds, "second");
	} else if (Math.abs(seconds) < 3600) {
		text = rtf.format(Math.round(seconds / 60), "minute");
	} else if (Math.abs(seconds) < 86400) {
		text = rtf.format(Math.round(seconds / 3600), "hour");
	} else {
		text = rtf.format(Math.round(seconds / 86400), "day");
	}
	el.textContent = text;
	el.title = new Date(then).toString();
}

/* Auto-refresh: poll with a HEAD request once a minute and reload only
 * when the page validators say a new version was actually published,
 * so nothing on screen ever moves for nothing. */
function setupAutoRefresh() {
	let current = null;

	function check() {
		fetch(location.href, { method: "HEAD", cache: "no-store" })
			.then((response) => {
				const version = response.headers.get("ETag") ||
					response.headers.get("Last-Modified");
				if (current && version && version != current) {
					location.reload();
				}
				current = version || current;
			})
			.catch((error) => console.log("auto-refresh: " + error));
	}

	check();
	setInterval(check, 60000);
}

/* Open every ready PR currently shown in the table that targets main,
 * each in its own tab. Most browsers allow a single popup per click
 * and silently block the rest (window.open returns null), so count
 * the casualties and tell the user how to lift the limit instead of
 * failing mysteriously. */
function openReadyPRs() {
	const rows = prTable.rows(
		(_index, _data, node) =>
			node.dataset.status == "ready" && node.dataset.base == "main",
		{search: "applied"},
	).nodes().toArray();

	if (rows.length == 0) {
		alert("No ready PRs targeting main in the current view.");
		return;
	}
	const blocked = rows.filter((row) => {
		const link = row.querySelector("a");
		return link && window.open(link.href, "_blank") == null;
	}).length;

	if (blocked > 0) {
		alert(`The browser blocked ${blocked} of ${rows.length} tabs. ` +
			"Allow pop-ups for this site (look for the blocked pop-up " +
			"icon in the address bar) to open all ready PRs at once.");
	}
}

/* Build one filter chip per target branch found in the table, "main"
 * first. The chip group only appears when there is a choice to make. */
function buildTargetChips(rows) {
	const group = document.getElementById("target-chips");

	const counts = new Map();
	rows.forEach((row) => {
		counts.set(row.dataset.base, (counts.get(row.dataset.base) || 0) + 1);
	});

	const bases = [...counts.keys()].sort(
		(a, b) => (a != "main") - (b != "main") || a.localeCompare(b));
	["", ...bases].forEach((base) => {
		const chip = document.createElement("button");
		chip.className = "chip";
		chip.dataset.target = base;
		chip.textContent = base || "All";
		chip.insertAdjacentHTML("beforeend",
			` <span class="count">${base ? counts.get(base) : rows.length}</span>`);
		group.appendChild(chip);
	});
	group.hidden = bases.length < 2;
}

function activateChip(chips, key, value) {
	const selected = chips.find((chip) =>
		!chip.hidden && chip.dataset[key] == value) || chips[0];

	chips.forEach((chip) =>
		chip.classList.toggle("active", chip == selected));
	return selected.dataset[key];
}

/* DataTables owns searching, exact target filtering, ordering, responsive
 * columns, empty-state rendering and saved state. The redesigned controls
 * stay in place and drive its API. */
function setupDataTable() {
	const rows = [...document.querySelectorAll("#pr-table tbody tr")];
	const search = document.getElementById("pr-search");
	const controls = document.querySelector(".controls");
	/* Overlap the filters by one pixel so fractional layout heights cannot
	 * expose scrolling rows at the seam. */
	const fixedHeaderOffset = () =>
		Math.max(0, controls.offsetHeight - 1);

	buildTargetChips(rows);
	const statusChips = [...document.querySelectorAll("#status-chips .chip")];
	const targetChips = [...document.querySelectorAll("#target-chips .chip")];
	const rowText = new Map(
		rows.map((row) => [row, row.textContent.toLowerCase()]));

	const counts = {};
	rows.forEach((row) => {
		counts[row.dataset.status] = (counts[row.dataset.status] || 0) + 1;
	});
	statusChips.forEach((chip) => {
		const count = chip.dataset.status
			? counts[chip.dataset.status] || 0
			: rows.length;
		chip.hidden = chip.hidden && count == 0;
		chip.insertAdjacentHTML("beforeend",
			` <span class="count">${count}</span>`);
	});

	let status = "";

	/* A chip's count answers "how many rows would this show?": the text
	 * search and the other chip group apply, its own group does not. */
	function updateChipCounts(table) {
		const text = table.search().trim().toLowerCase();
		const selectedTarget = table.column(5).search();
		const candidates = rows.filter((row) =>
			!text || rowText.get(row).includes(text));

		statusChips.forEach((chip) => {
			const value = chip.dataset.status;
			chip.querySelector(".count").textContent = candidates.filter(
				(row) => (!selectedTarget ||
					row.dataset.base == selectedTarget) &&
					(!value || row.dataset.status == value)).length;
		});
		targetChips.forEach((chip) => {
			const value = chip.dataset.target;
			chip.querySelector(".count").textContent = candidates.filter(
				(row) => (!status || row.dataset.status == status) &&
					(!value || row.dataset.base == value)).length;
		});
	}

	prTable = new DataTable("#pr-table", {
		paging: false,
		info: false,
		/* Let the stylesheet own column widths (see the .prs caps above). */
		autoWidth: false,
		order: [],
		orderClasses: false,
		stateSave: true,
		stateDuration: 0,
		fixedHeader: {
			headerOffset: fixedHeaderOffset(),
		},
		layout: {
			topStart: null,
			topEnd: null,
			bottomStart: null,
			bottomEnd: null,
		},
		responsive: {
			details: {
				renderer: DataTable.Responsive.renderer.listHiddenNodes(),
			},
		},
		language: {
			emptyTable: "No pull requests are currently available.",
			zeroRecords: "No pull requests match the current filter.",
		},
		stateLoadParams: (_settings, data) => {
			data.order = [];
			if (data.columns?.length == 10) {
				const oldColumns = data.columns;
				data.columns = [oldColumns[0], oldColumns[1], oldColumns[5],
					oldColumns[6], oldColumns[7], oldColumns[8],
					oldColumns[9], oldColumns[2]];
			}
			if (data.columns?.length != 8) {
				return false;
			}
			status = data.statusFilter || "";
		},
		stateSaveParams: (_settings, data) => {
			data.order = [];
			data.statusFilter = status;
		},
		/* Narrow screens keep title, readiness, PR and author; the target,
		 * assignee, approver and milestone columns drop first. */
		columnDefs: [
			{targets: 1, responsivePriority: 1},
			{
				targets: 7,
				orderable: false,
				responsivePriority: 2,
			},
			{targets: 0, type: "html-num", responsivePriority: 3},
			{targets: 2, responsivePriority: 4},
			{targets: [3, 4, 5, 6], responsivePriority: 10},
		],
		drawCallback: function () {
			const table = this.api();
			table.rows().nodes().each((row) => row.classList.remove("stripe"));
			table.rows({search: "applied"}).nodes().each((row, index) =>
				row.classList.toggle("stripe", index % 2 == 1));
			updateChipCounts(table);
		},
	});

	search.value = prTable.search();
	search.addEventListener("input", () =>
		prTable.search(search.value).draw());

	status = activateChip(statusChips, "status", status);
	prTable.search.fixed("status", (_search, _data, index) =>
		!status || rows[index].dataset.status == status);

	statusChips.forEach((chip) => {
		chip.addEventListener("click", () => {
			status = activateChip(statusChips, "status", chip.dataset.status);
			prTable.draw();
		});
	});

	let target = activateChip(
		targetChips, "target", prTable.column(5).search());
	prTable.column(5).search(target, {exact: true});

	targetChips.forEach((chip) => {
		chip.addEventListener("click", () => {
			target = activateChip(targetChips, "target", chip.dataset.target);
			prTable.column(5).search(target, {exact: true}).draw();
		});
	});

	prTable.draw();

	const updateHeaderOffset = () =>
		prTable.fixedHeader.headerOffset(fixedHeaderOffset());

	/* autoWidth is off, so re-fit columns and responsive visibility ourselves. */
	let relayoutPending;
	addEventListener("resize", () => {
		clearTimeout(relayoutPending);
		relayoutPending = setTimeout(() => {
			prTable.columns.adjust();
			prTable.responsive.recalc();
			updateHeaderOffset();
		}, 100);
	});

	/* Track the filter bar's height (it wraps) to keep FixedHeader's offset right. */
	if (window.ResizeObserver) {
		new ResizeObserver(updateHeaderOffset).observe(controls);
	}
}

/* Close the help dialog when the backdrop is clicked; Esc already works
 * natively. Clicks inside the content land on .help-body, not here. */
function setupHelpDialog() {
	const dialog = document.getElementById("help-dialog");
	dialog.addEventListener("click", (event) => {
		if (event.target == dialog) {
			dialog.close();
		}
	});
}

addEventListener("DOMContentLoaded", () => {
	lucide.createIcons();
	loadMotd();
	renderUpdateTime();
	setInterval(renderUpdateTime, 1000);
	setupAutoRefresh();
	setupDataTable();
	setupHelpDialog();
});
</script>

</head>

<body>

<div class="page-header">
	<h1>Zephyr merge list</h1>
	<p class="subtitle">Open pull requests that are approved, pass CI, and are
	in line to be merged into
	<a href="https://github.com/zephyrproject-rtos/zephyr">zephyrproject-rtos/zephyr</a>.
	<button class="help-link"
		onclick="document.getElementById('help-dialog').showModal()">How this list
		works</button></p>
</div>

<dialog class="help" id="help-dialog" aria-labelledby="help-title">
	<div class="help-body">
	<div class="help-header">
		<h3 id="help-title">How this list works</h3>
		<button class="help-close" aria-label="Close"
			onclick="document.getElementById('help-dialog').close()">&#10005;</button>
	</div>

	<h4>Which PRs show up here?</h4>
	<p>Every open, non-draft pull request that is approved by reviewers and
	passing CI. Code review is done: this page tracks the final wait for a
	release engineer to apply the project's
	<a href="https://docs.zephyrproject.org/latest/project/release_process.html#pull-request-merge-criteria">merge criteria</a>.</p>

	<h4>When is a PR ready to merge?</h4>
	<p>When all three icons in <b>Ready to merge?</b> are green:</p>
	<ul class="help-gates">
		<li><span class="gate-icon gate-conflict gate-pass" aria-hidden="true"><i
			data-lucide="git-merge"></i></span>
			<span><b>Conflict-free</b> &mdash; applies cleanly.</span></li>
		<li><span class="gate-icon gate-approval gate-pass" aria-hidden="true"><i
			data-lucide="user-round-check"></i></span>
			<span><b>Assignee approved</b> &mdash; automatic for hotfixes,
			unassigned PRs, and self-assignees.</span></li>
		<li><span class="gate-icon gate-review gate-pass" aria-hidden="true"><i
			data-lucide="clock-check"></i></span>
			<span><b>Review window elapsed</b> &mdash;
			{{REVIEW_WINDOW_BIZ_HOURS}} business hours,
			{{REVIEW_WINDOW_TRIVIAL_HOURS}} for trivial PRs, none for
			hotfixes.</span></li>
	</ul>
	<p><b>Red means action is needed:</b></p>
	<ul class="help-gates">
		<li><span class="gate-icon gate-conflict gate-fail" aria-hidden="true"><i
			data-lucide="git-merge-conflict"></i></span>
			<span><b>Merge conflict</b> &mdash; rebase the PR branch onto the
			latest target branch and resolve any conflicts.</span></li>
		<li><span class="gate-icon gate-approval gate-fail" aria-hidden="true"><i
			data-lucide="user-round-x"></i></span>
			<span><b>Approval missing</b> &mdash; at least one assignee must
			approve.</span></li>
	</ul>
	<p class="help-gate-note"><span class="gate-icon gate-review gate-wait"
		aria-hidden="true"><i data-lucide="clock-3"></i></span>
		<span>A yellow clock shows the hours remaining
		in the review window.</span></p>

	<h4>My PR has three green icons. Why hasn&rsquo;t it been merged?</h4>
	<p>Release engineers process ready PRs several times a day, so it will
	probably be merged within a few hours.</p>

	<h4><a href="https://docs.zephyrproject.org/latest/project/dev_env_and_tools.html#labeling-issues-and-pull-requests-in-github">Labels</a></h4>
	<table>
		<tr><td><span class="tag tag-hotfix">hotfix</span></td>
			<td>Fixes a broken main branch; merged immediately.</td></tr>
		<tr><td><span class="tag tag-trivial">trivial</span></td>
			<td>Small, low-risk change; the review window is {{REVIEW_WINDOW_TRIVIAL_HOURS}} hours instead of {{REVIEW_WINDOW_BIZ_HOURS}} business hours.</td></tr>
		<tr><td><span class="tag tag-override">override required</span></td>
			<td>A release engineer must override a failing or stuck required check to merge.</td></tr>
		<tr><td><span class="tag tag-oldci">ci 42d</span></td>
			<td>The last full CI run is that many days old; CI should be re-run before merging.</td></tr>
		<tr><td><span class="tag tag-dismissed">review dismissed</span></td>
			<td>A &ldquo;changes requested&rdquo; review was dismissed by someone else; merits a second look.</td></tr>
		<tr><td><span class="tag tag-dnm">dnm</span></td>
			<td>Do not merge.</td></tr>
	</table>

	<h4>Release phase</h4>
	<p>During <b>integration</b>, features and fixes merge normally. During
	<a href="https://docs.zephyrproject.org/latest/project/release_process.html#feature-freeze-stabilization-phase">feature
	freeze</a>, only bug fixes and release-blocking work are merged, and PRs
	milestoned for the next release wait.</p>
	</div>
</dialog>

<div class="motd" id="motd" role="alert" hidden></div>

<div class="metabar">
	<span><span class="meta-label">Updated</span><time id="update-timestamp" datetime="{{UPDATE_TIMESTAMP}}">{{UPDATE_TIMESTAMP}}</time></span>
	<span class="meta-sep">|</span>
	<span><span class="meta-label">CI on main:</span><span class="ci-badges">{{CI_STATUS}}</span></span>
</div>

<div class="controls">
	<input type="search" id="pr-search"
		placeholder="Filter by number, title, author, branch&hellip;"
		aria-label="Filter pull requests">
	<div class="chips" id="status-chips" role="group" aria-label="Filter by status">
		<button class="chip active" data-status="">All</button>
		<button class="chip" data-status="ready">Ready</button>
		<button class="chip" data-status="waiting">Waiting</button>
		<button class="chip" data-status="blocked">Blocked</button>
		<button class="chip" data-status="unknown" hidden>Checking</button>
	</div>
	<!-- Filled by setupDataTable(): one chip per target branch in the table. -->
	<div class="chips" id="target-chips" role="group"
		aria-label="Filter by target branch" hidden>
		<span class="chips-label">Target branch:</span>
	</div>
</div>

<div class="table-wrap">
<table class="prs responsive" id="pr-table">
	<thead>
	<tr>
		<th title="Pull request number (click to sort)">PR</th>
		<th title="Pull request title and labels (click to sort)">Title</th>
		<th title="Who opened the PR (click to sort)">Author</th>
		<th title="Maintainers assigned to shepherd the PR (click to sort)">Assignees</th>
		<th title="Reviewers whose approval currently stands (click to sort)">Approvers</th>
		<th title="Branch the PR will be merged into (click to sort)">Target</th>
		<th title="Release milestone, if set (click to sort)">Milestone</th>
		<th class="gate-col" title="Ready to merge? Left to right: conflict-free, assignee approval, review time">Ready to merge?</th>
	</tr>
	</thead>
	<tbody>
