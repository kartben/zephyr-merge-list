	<a href="https://github.com/{{REPOSITORY_PATH}}/actions/workflows/update.yaml">
		<img src="https://github.com/{{REPOSITORY_PATH}}/actions/workflows/update.yaml/badge.svg" alt="update workflow status">
	</a>
	&mdash; generated by <a href="https://github.com/{{REPOSITORY_PATH}}">{{REPOSITORY_PATH}}</a>
</footer>

</body>
</html>
