
	</tbody>
</table>
</div>

<div class="toolbar">
	<button onclick="openReadyPRs()" class="open-ready-button">Open all ready PRs &nearr;</button>
</div>

<p class="phase" title="{{RELEASE_PHASE_HINT}}"><b>{{RELEASE_PHASE}}</b> <span class="muted">&middot; {{RELEASE_PHASE_DETAIL}}</span></p>

